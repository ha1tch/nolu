# Dockerfile.iolu
#
# Thin wrapper that overrides the entrypoint of the xolu runtime image
# to run iolu instead of olu. Both binaries ship in ghcr.io/ha1tch/xolu:latest.
#
# Usage in compose (init container pattern):
#   entrypoint: ["/usr/local/bin/iolu"]
#   command: ["tenant", "create", "--db", "/data/olu.db", "--name", "mytenant"]

FROM ghcr.io/ha1tch/xolu:latest
ENTRYPOINT ["/usr/local/bin/iolu"]
